      { title: "Hoşgörü", icon: "fa-users", image: "https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?q=80&w=1200&auto=format&fit=crop", definition: "Farklı düşünce ve davranışlara anlayışla yaklaşmaktır.", verse: "Dinde zorlama yoktur. (Bakara, 256)", hadith: "Peygamberimiz farklı insanlara karşı anlayışlı davranmıştır.", digital: "İnternette farklı görüşlere hakaret etmeden yaklaşmak." },
      { title: "Yardımlaşma", icon: "fa-hands-helping", image: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200&auto=format&fit=crop", definition: "İnsanların birbirine destek olması ve iyiliği paylaşmasıdır.", verse: "İyilik ve takva üzerinde yardımlaşın. (Maide, 2)", hadith: "Mümin müminin kardeşidir.", digital: "Faydalı bilgi paylaşmak, ihtiyaç sahiplerine çevrim içi destek olmak." },
      { title: "Güven", icon: "fa-shield-alt", image: "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=1200&auto=format&fit=crop", definition: "İnsanların birbirine inanması ve güven duymasıdır.", verse: "Emanetleri ehline verin. (Nisa, 58)", hadith: "Müslüman, insanların elinden ve dilinden emin olduğu kişidir.", digital: "Güvenilir internet sitelerini kullanmak, şifreleri ve kişisel bilgileri korumak." },
      { title: "Emanet", icon: "fa-lock", image: "https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=1200&auto=format&fit=crop", definition: "Korunması gereken bir şeyi güvenle muhafaza etmektir.", verse: "Allah size emanetleri ehline vermenizi emrediyor. (Nisa, 58)", hadith: "Peygamberimiz 'El-Emin' olarak bilinirdi.", digital: "Başkasının hesabını izinsiz kullanmamak, kişisel bilgileri korumak." }
    ];

    function renderConcepts() {
      const grid = document.getElementById('conceptsGrid');
      grid.innerHTML = concepts.map((concept, index) => `
        <article class="concept-card" data-index="${index}">
          <div class="card-image">
            <img src="${concept.image}" alt="${concept.title}" loading="lazy">
            <span class="card-badge">Kavram ${index + 1}</span>
          </div>
          <div class="card-body">
            <h3 class="card-title"><i class="fas ${concept.icon}"></i> ${concept.title}</h3>
            <div class="card-section">
              <div class="card-label"><i class="fas fa-book"></i> Tanım</div>
              <p class="card-text">${concept.definition}</p>
            </div>
            <div class="card-section">
              <div class="card-label"><i class="fas fa-quran"></i> Ayet</div>
              <div class="quote-box">
                <p>${concept.verse}</p>
              </div>
            </div>
            <div class="card-section">
              <div class="card-label"><i class="fas fa-mosque"></i> Hadis / Sünnet</div>
              <p class="card-text">${concept.hadith}</p>
            </div>
            <div class="card-section">
              <div class="card-label"><i class="fas fa-laptop"></i> Dijital Karşılığı</div>
              <span class="digital-tag"><i class="fas fa-wifi"></i> ${concept.digital}</span>
            </div>
          </div>
        </article>
      `).join('');
    }

    function searchConcept() {
      const input = document.getElementById('searchInput').value.toLocaleLowerCase('tr-TR');
      const cards = document.querySelectorAll('.concept-card');
      cards.forEach(card => {
        const text = card.innerText.toLocaleLowerCase('tr-TR');
        if (text.includes(input)) {
          card.style.display = 'block';
          card.style.animation = 'fadeInUp 0.5s ease';
        } else {
          card.style.display = 'none';
        }
      });
    }

      const questions = [
      {q: "Başkasının fotoğrafını izinsiz paylaşmamak hangi değerdir?", a: ["Ölçülülük", "Vefa", "Mahremiyet"], c: 2},
      {q: "Doğruluğundan emin olmadığımız haberi paylaşmamak hangi değeri gösterir?", a: ["Dürüstlük", "Sabır", "Hoşgörü"], c: 0},
      {q: "Yorum yazmadan önce karşı tarafın duygusunu düşünmek hangi kavramdır?", a: ["Emanet", "Adalet", "Empati"], c: 2},
      {q: "İzinsiz içerik kopyalamamak hangi değerle ilgilidir?", a: ["Merhamet", "Nezaket", "Kul Hakkı"], c: 2},
      {q: "Ekran süresini dengeli kullanmak hangi kavramdır?", a: ["Ölçülülük", "Adalet", "Mahremiyet"], c: 0},
      {q: "Sosyal medyada hakaret etmemek hangi değeri gösterir?", a: ["Saygı", "Gösteriş", "İhmal"], c: 0},
      {q: "Kırıcı mesaj yerine nazik bir ifade kullanmak hangi kavramdır?", a: ["Nezaket", "Öfke", "Kul Hakkı"], c: 0},
      {q: "Zor durumda olan biriyle alay etmemek hangi değeri gösterir?", a: ["Rekabet", "Merhamet", "Dürüstlük"], c: 1},
      {q: "Bir paylaşımın sonuçlarını düşünerek hareket etmek hangi kavramdır?", a: ["Sabırsızlık", "Sorumluluk", "Kıskançlık"], c: 1},
      {q: "Bir kişiyi sosyal medyada haksız yere suçlamamak hangi değerdir?", a: ["İsraf", "Adalet", "Tembellik"], c: 1},
      {q: "Öfkeliyken hakaret etmemek hangi değeri gösterir?", a: ["Sabır", "Kul Hakkı", "Gösteriş"], c: 0},
      {q: "Farklı görüşlere hakaret etmeden yaklaşmak hangi kavramdır?", a: ["Dürüstlük", "İhmal", "Hoşgörü"], c: 2},
      {q: "Faydalı bilgi paylaşmak ve destek olmak hangi değerle ilgilidir?", a: ["Yardımlaşma", "Kıskançlık", "Sabırsızlık"], c: 0},
      {q: "Güvenilir internet sitelerini kullanmak ve şifreleri korumak hangi kavramla ilişkilidir?", a: ["Rekabet", "Güven", "Gösteriş"], c: 1},
      {q: "Başkasının hesabını izinsiz kullanmamak hangi değerdir?", a: ["Öfke", "Emanet", "Tembellik"], c: 1}
    ];

    let currentQuestion = 0;
    let score = 0;
    let answered = 0;

    function initQuiz() {
      const quizArea = document.getElementById('quizArea');
      const quizProgress = document.getElementById('quizProgress');
      const quizResult = document.getElementById('quizResult');
      quizArea.innerHTML = '';
      quizProgress.style.display = 'flex';
      quizResult.classList.remove('show');
      currentQuestion = 0;
      score = 0;
      answered = 0;
      updateProgress();
      showQuestion(0);
    }

    function showQuestion(index) {
      const quizArea = document.getElementById('quizArea');
      const item = questions[index];
      const card = document.createElement('div');
      card.className = 'quiz-card';
      card.innerHTML = `
        <div class="quiz-number">${index + 1}</div>
        <p class="quiz-question">${item.q}</p>
        <div class="quiz-options">
          ${item.a.map((choice, i) => `
            <div class="quiz-option" onclick="selectOption(this, ${i}, ${item.c}, ${index})">
              <span class="option-letter">${String.fromCharCode(65 + i)}</span>
              <span>${choice}</span>
            </div>
          `).join('')}
        </div>
      `;
      quizArea.appendChild(card);
      setTimeout(() => card.classList.add('active'), 50);
    }

    function selectOption(element, selected, correct, qIndex) {
      const card = element.closest('.quiz-card');
      if (card.dataset.answered === 'true') return;
      card.dataset.answered = 'true';
      answered++;
      const options = card.querySelectorAll('.quiz-option');
      options.forEach((opt, i) => {
        opt.classList.add('disabled');
        if (i === correct) {
          opt.classList.add('correct');
        } else if (i === selected && i !== correct) {
          opt.classList.add('wrong');
        }
      });
      if (selected === correct) score++;
      updateProgress();
      setTimeout(() => {
        if (qIndex < questions.length - 1) {
          card.style.opacity = '0';
          card.style.transform = 'translateX(-50px)';
          setTimeout(() => {
            card.remove();
            showQuestion(qIndex + 1);
          }, 400);
        } else {
          showResult();
        }
      }, 1200);
    }

    function updateProgress() {
      document.getElementById('progressText').textContent = `Soru ${Math.min(answered + 1, questions.length)} / ${questions.length}`;
      document.getElementById('scoreText').textContent = `Puan: ${score}`;
      document.getElementById('progressFill').style.width = `${(answered / questions.length) * 100}%`;
    }

    function showResult() {
      document.getElementById('quizArea').innerHTML = '';
      document.getElementById('quizProgress').style.display = 'none';
      const result = document.getElementById('quizResult');
      result.classList.add('show');
      document.getElementById('resultScore').textContent = `${score} / ${questions.length}`;
      const percentage = (score / questions.length) * 100;
      let message = '';
      if (percentage >= 90) message = 'Mükemmel! Dijital ahlak konusunda uzman seviyesindesiniz!';
      else if (percentage >= 70) message = 'Çok iyi! Dijital ahlak bilginiz oldukça gelişmiş.';
      else if (percentage >= 50) message = 'İyi gidiyorsunuz! Biraz daha pratik yapabilirsiniz.';
      else message = 'Daha fazla çalışmanız gerekiyor. Kavramları tekrar inceleyin!';
      document.getElementById('resultMessage').textContent = message;
      const starsContainer = document.getElementById('resultStars');
      starsContainer.innerHTML = '';
      const starCount = Math.ceil((score / questions.length) * 5);
      for (let i = 0; i < 5; i++) {
        const star = document.createElement('i');
        star.className = 'fas fa-star' + (i < starCount ? ' filled' : '');
        if (i < starCount) {
          star.style.animationDelay = `${i * 0.1}s`;
        }
        starsContainer.appendChild(star);
      }
    }

    function restartQuiz() {
      initQuiz();
    }

    function scrollToTop() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function toggleMobileMenu() {
      const navLinks = document.querySelector('.nav-links');
      navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
      navLinks.style.position = 'absolute';
      navLinks.style.top = '72px';
      navLinks.style.left = '0';
      navLinks.style.right = '0';
      navLinks.style.background = 'rgba(255,255,255,0.95)';
      navLinks.style.backdropFilter = 'blur(20px)';
      navLinks.style.flexDirection = 'column';
      navLinks.style.padding = '20px';
      navLinks.style.boxShadow = '0 10px 30px rgba(0,0,0,0.1)';
    }

    // Counter Animation
    function animateCounters() {
      const counters = document.querySelectorAll('.counter');
      counters.forEach(counter => {
        const target = parseInt(counter.getAttribute('data-target'));
        const duration = 2000;
        const step = target / (duration / 16);
        let current = 0;
        const updateCounter = () => {
          current += step;
          if (current < target) {
            counter.textContent = Math.floor(current);
            requestAnimationFrame(updateCounter);
          } else {
            counter.textContent = target;
          }
        };
        updateCounter();
      });
    }

    // Scroll Reveal
    function revealOnScroll() {
      const cards = document.querySelectorAll('.concept-card');
      cards.forEach((card, index) => {
        const rect = card.getBoundingClientRect();
        if (rect.top < window.innerHeight - 100) {
          setTimeout(() => card.classList.add('visible'), index * 100);
        }
      });
    }

    // Navbar scroll effect
    function handleNavbar() {
      const navbar = document.getElementById('navbar');
      if (window.scrollY > 50) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    }

    // Back to top button
    function handleBackToTop() {
      const btn = document.getElementById('backToTop');
      if (window.scrollY > 500) {
        btn.classList.add('visible');
      } else {
        btn.classList.remove('visible');
      }
    }

    // Create particles
    function createParticles() {
      const container = document.getElementById('particles');
      for (let i = 0; i < 30; i++) {
        const particle = document.createElement('div');
        particle.className = 'particle';
        particle.style.left = Math.random() * 100 + '%';
        particle.style.animationDelay = Math.random() * 15 + 's';
        particle.style.animationDuration = (10 + Math.random() * 10) + 's';
        container.appendChild(particle);
      }
    }

    // Initialize
    window.addEventListener('load', () => {
      document.getElementById('loader').classList.add('hidden');
      renderConcepts();
      createParticles();
      animateCounters();
      initQuiz();
      revealOnScroll();
    });

    window.addEventListener('scroll', () => {
      handleNavbar();
      handleBackToTop();
      revealOnScroll();
    });
  </script>
</body>
</html>
